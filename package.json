    "fs-extra": "^11.2.0",
    "google-it": "^1.6.0",
    "image-to-base64": "^2.2.0",
    "jsdom": "^24.0.0",
    "mime-types": "^2.1.35",
    "moment-timezone": "^0.5.45",
    "node-fetch": "^3.3.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "qrcode-terminal": "^0.12.0",
    "wa-sticker-formatter": "^4.4.4",
