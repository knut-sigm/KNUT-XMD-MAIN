{
  "name": "knut-xmd",
  "version": "3.0.0",
  "description": "Bot WhatsApp multi-fonctions stable (Baileys 6.7.19, KNUT)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --trace-warnings index.js",
    "dev": "nodemon index.js",
    "setup": "node setup.js",
    "install-deps": "npm install --legacy-peer-deps --force",
    "update": "npm update",
    "install-translate": "npm install @vitalets/google-translate-api",
    "pm2": "pm2 start index.js --name knut-xmd",
    "pm2:restart": "pm2 restart knut-xmd",
    "pm2:stop": "pm2 stop knut-xmd",
    "pm2:delete": "pm2 delete knut-xmd",
    "pm2:logs": "pm2 logs knut-xmd",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "pm2:list": "pm2 list",
    "pm2:status": "pm2 status",
    "deploy": "pm2 start index.js --name knut-xmd --watch",
    "deploy:production": "pm2 start index.js --name knut-xmd --watch --max-memory-restart 300M",
    "pterodactyl:setup": "node -e \"console.log('Configuration pour Pterodactyl...')\"",
    "pterodactyl:restart": "touch restart.txt && exit 0",
    "postinstall": "node -e \"console.log('\\n\\x1b[36m%s\\x1b[0m', '💡 KNUT XMD - Installation terminée !'); console.log('\\x1b[33m%s\\x1b[0m', '👉 Pour PM2: npm run pm2'); console.log('\\x1b[33m%s\\x1b[0m', '👉 Pour Pterodactyl: Configurez votre startup command\\n')\""
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@vitalets/google-translate-api": "^9.2.0",
    "@whiskeysockets/baileys": "^6.7.19",
    "axios": "^1.7.5",
    "buffer": "^6.0.3",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "ffmpeg": "^0.0.4",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.2.0",
    "google-it": "^1.6.0",
    "image-to-base64": "^2.2.0",
    "jimp": "^1.6.0",
    "jsdom": "^24.0.0",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45",
    "mumaker": "^2.0.0",
    "music-metadata": "^7.14.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "node-gtts": "^2.0.2",
    "node-webpmux": "^3.2.1",
    "os": "^0.1.2",
    "pdfkit": "^0.14.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "pm2": "^5.3.1",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.33.5",
    "string-similarity": "^4.0.4",
    "util": "^0.12.5",
    "wa-sticker-formatter": "^4.4.4",
    "wallpaper": "^6.1.1",
    "weather-js": "^2.0.0",
    "yt-search": "^2.12.1",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0 || >=21.0.0"
  },
  "engineStrict": false,
  "keywords": [
    "whatsapp",
    "bot",
    "baileys",
    "multifunction",
    "knut",
    "whatsapp-bot",
    "whatsapp-api",
    "whatsapp-web",
    "pm2",
    "pterodactyl"
  ],
  "author": "Knut XMD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knut-sigm/KNUT-XMD-MAIN.git"
  },
  "bugs": {
    "url": "https://github.com/knut-sigm/KNUT-XMD-MAIN/issues"
  },
  "homepage": "https://github.com/knut-sigm/KNUT-XMD-MAIN#readme",
  "pm2": {
    "name": "knut-xmd",
    "script": "index.js",
    "watch": false,
    "ignore_watch": ["node_modules", "session", "*.log"],
    "max_memory_restart": "500M",
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "production"
    }
  },
  "pterodactyl": {
    "startup": "npm run start",
    "stop": "npm run pterodactyl:restart"
  }
}
