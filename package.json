  "description": "Bot WhatsApp multi-fonctions stable (Baileys 6.7.19, KNUT)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --trace-warnings index.js",
    "dev": "nodemon index.js",
    "install-deps": "npm install --force --legacy-peer-deps",
